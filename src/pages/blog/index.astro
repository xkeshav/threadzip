---
import { getCollection, type CollectionEntry } from "astro:content";
import Nav from "../../components/Nav.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import Layout from "../../layouts/Layout.astro";

type BlogPost = CollectionEntry<"blog">;

const posts = (await getCollection("blog")).sort(
  (a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const allTags = [...new Set(posts.flatMap((p: BlogPost) => p.data.tags))].sort();
const featured = posts.find((p: BlogPost) => p.data.featured);
const rest = posts.filter((p: BlogPost) => !p.data.featured);
---

<Layout title="Blog — Threadzip" description="Insights on the fabric industry, AI, and commerce.">
  <Nav />
  <main class="blog-index">
    <div class="blog-index-header">
      <div class="section-label">Journal</div>
      <h1>Fabric Industry <em>Insights</em></h1>
      <p class="blog-index-intro">Data, analysis, and perspectives on the global textile trade.</p>

      <div class="tag-filter">
        <a href="/blog" class="tag-pill active">All</a>
        {allTags.map((tag) => (
          <a href={`/blog/tag/${tag}`} class="tag-pill">#{tag}</a>
        ))}
      </div>
    </div>

    {featured && (
      <a href={`/blog/${featured.id}`} class="featured-post">
        <div class="featured-meta">
          <span class="featured-badge">Featured</span>
          {featured.data.tags.slice(0, 3).map((tag: string) => (
            <span class="featured-tag">#{tag}</span>
          ))}
        </div>
        <h2 class="featured-title">{featured.data.title}</h2>
        <p class="featured-desc">{featured.data.description}</p>
        <div class="featured-footer">
          <span class="featured-author">{featured.data.author}</span>
          <span class="featured-sep">·</span>
          <time>{new Date(featured.data.pubDate).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</time>
          <span class="featured-read">Read article →</span>
        </div>
      </a>
    )}

    {rest.length > 0 && (
      <div class="posts-grid">
        {rest.map((post: BlogPost) => (
          <a href={`/blog/${post.id}`} class="post-card">
            <div class="post-tags">
              {post.data.tags.slice(0, 2).map((tag: string) => (
                <span class="post-tag">#{tag}</span>
              ))}
            </div>
            <h3 class="post-title">{post.data.title}</h3>
            <p class="post-desc">{post.data.description}</p>
            <div class="post-meta">
              <time>{new Date(post.data.pubDate).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</time>
            </div>
          </a>
        ))}
      </div>
    )}
  </main>
  <SiteFooter />
</Layout>

<style>
  .blog-index {
    padding-top: 80px;
    min-height: 100vh;
    background: var(--ink);
  }

  .blog-index-header {
    padding: 60px 40px 48px;
    max-width: 900px;
    margin: 0 auto;
  }

  .blog-index-header h1 {
    font-size: clamp(36px, 5vw, 60px);
    margin-bottom: 16px;
  }

  .blog-index-intro {
    font-size: 16px;
    font-weight: 300;
    color: var(--muted);
    margin-bottom: 32px;
  }

  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag-pill {
    font-size: 12px;
    font-weight: 500;
    padding: 5px 14px;
    border-radius: 20px;
    border: 0.5px solid var(--border-strong);
    color: var(--muted);
    text-decoration: none;
    transition: all 0.2s;
    letter-spacing: 0.02em;
  }
  .tag-pill:hover, .tag-pill.active {
    background: rgba(200,133,58,0.12);
    border-color: var(--amber);
    color: var(--amber);
  }

  /* Featured */
  .featured-post {
    display: block;
    margin: 0 40px 48px;
    max-width: 820px;
    margin-left: auto;
    margin-right: auto;
    background: var(--ink-2);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 40px 44px;
    text-decoration: none;
    transition: border-color 0.3s, transform 0.3s;
    position: relative;
    overflow: hidden;
  }
  .featured-post::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--amber), var(--amber-light));
  }
  .featured-post:hover { border-color: var(--amber-dim); transform: translateY(-2px); }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .featured-badge {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 10px;
    background: rgba(200,133,58,0.18);
    color: var(--amber);
    border-radius: 20px;
  }

  .featured-tag {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .featured-title {
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--surface);
    line-height: 1.15;
    margin-bottom: 14px;
  }

  .featured-desc {
    font-size: 15px;
    font-weight: 300;
    color: var(--muted);
    line-height: 1.65;
    margin-bottom: 24px;
    max-width: 600px;
  }

  .featured-footer {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--muted-2);
    flex-wrap: wrap;
  }

  .featured-author { font-weight: 500; color: var(--muted); }
  .featured-sep { opacity: 0.4; }

  .featured-read {
    margin-left: auto;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    color: var(--amber);
    letter-spacing: 0.02em;
  }

  /* Posts grid */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    padding: 0 40px 80px;
    max-width: 900px;
    margin: 0 auto;
  }

  .post-card {
    background: var(--ink-2);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px 24px;
    text-decoration: none;
    transition: border-color 0.3s, transform 0.3s;
    display: flex;
    flex-direction: column;
  }
  .post-card:hover { border-color: var(--amber-dim); transform: translateY(-2px); }

  .post-tags {
    display: flex;
    gap: 6px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .post-tag {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--amber);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--surface);
    line-height: 1.3;
    margin-bottom: 10px;
  }

  .post-desc {
    font-size: 13px;
    font-weight: 300;
    color: var(--muted);
    line-height: 1.6;
    flex: 1;
    margin-bottom: 16px;
  }

  .post-meta {
    font-size: 11px;
    color: var(--muted-2);
  }

  @media (max-width: 900px) {
    .blog-index-header { padding: 40px 20px 32px; }
    .featured-post { margin: 0 20px 32px; padding: 28px 24px; }
    .posts-grid { grid-template-columns: 1fr; padding: 0 20px 60px; }
  }
</style>
