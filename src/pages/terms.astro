---
import { getEntry, render } from "astro:content";
import company from "../data/company.json";
import PageLayout from "../layouts/PageLayout.astro";

const entry = await getEntry("legal", "terms");
if (!entry) throw new Error("terms not found");
const { Content } = await render(entry);
---

<PageLayout title="Terms of Service" eyebrow="Legal" prose>
  <p class="prose-meta">
    Effective date: {entry.data.effectiveDate} &nbsp;·&nbsp; {company.name}
  </p>
  <div class="prose">
    <Content />
  </div>
</PageLayout>
