---
import Nav from "../components/Nav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Layout from "./Layout.astro";

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  prose?: boolean;
}

const { title, description, eyebrow, prose = false } = Astro.props;
---

<Layout title={`${title} — Threadzip`} description={description ?? title}>
  <Nav />
  <main class="page-main">
    <div class={`page-container${prose ? " prose-container" : ""}`}>
      {eyebrow && <div class="page-eyebrow">{eyebrow}</div>}
      <h1 class="page-title">{title}</h1>
      <slot />
    </div>
  </main>
  <SiteFooter />
</Layout>

<style is:global>
  .page-main {
    padding-top: 80px;
    min-height: 100vh;
    background: var(--ink);
  }

  .page-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 60px 40px 100px;
  }

  .prose-container {
    max-width: 720px;
  }

  .page-eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .page-eyebrow::before {
    content: '';
    width: 24px; height: 1px;
    background: var(--amber);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--surface);
    margin-bottom: 48px;
  }

  /* Prose styles for legal/markdown pages */
  .prose h2 {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--surface);
    margin: 2.4em 0 0.7em;
    letter-spacing: -0.01em;
  }

  .prose h3 {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    color: var(--surface);
    margin: 1.6em 0 0.5em;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .prose p {
    font-size: 15px;
    font-weight: 300;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 1.2em;
  }

  .prose ul, .prose ol {
    padding-left: 1.4em;
    margin-bottom: 1.2em;
  }

  .prose li {
    font-size: 15px;
    font-weight: 300;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 0.4em;
  }

  .prose a {
    color: var(--amber);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose strong { font-weight: 600; color: var(--surface); }

  .prose hr {
    border: none;
    border-top: 0.5px solid var(--border);
    margin: 2.4em 0;
  }

  .prose-meta {
    font-size: 13px;
    color: var(--muted-2);
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 0.5px solid var(--border);
  }

  @media (max-width: 768px) {
    .page-container { padding: 40px 20px 80px; }
  }
</style>
